CONTENTFUL_WEBHOOK_SECRET=your-webhook-secret-here
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Required for auto slug-change detection (Case 2)
CONTENTFUL_SPACE_ID=your-space-id
CONTENTFUL_CMA_TOKEN=your-cma-token
CONTENTFUL_ENVIRONMENT_ID=master

# Optional overrides for slug auto-detection
CONTENTFUL_SLUG_FIELD_ID=slug
CONTENTFUL_SLUG_LOCALE=en-US
CONTENTFUL_SLUG_PATH_PREFIX=

# Local testing only — simulates a prior published slug without real CMA credentials.
# Remove this when using real CONTENTFUL_SPACE_ID + CONTENTFUL_CMA_TOKEN.
MOCK_PREVIOUS_SLUG=old-blog-post
